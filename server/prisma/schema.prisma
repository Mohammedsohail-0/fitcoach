generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(uuid())
  username      String        @unique
  name          String
  role          String
  email         String        @unique
  password      String
  createdAt     DateTime      @default(now())
  coachProfile  CoachProfile?
  clientProfile ClientProfile?
}

model CoachProfile {
  id             String          @id @default(uuid())
  userId         String          @unique
  name           String
  bio            String?
  specialization String?
  createdAt      DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id])
  clients        ClientProfile[]
  workoutPlans   WorkoutPlan[]
  invitations    Invitation[]
}

model ClientProfile {
  id           String        @id @default(uuid())
  userId       String        @unique
  coachId      String
  name         String
  goal         String?
  notes        String?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id])
  coach        CoachProfile  @relation(fields: [coachId], references: [id])
  workoutPlans WorkoutPlan[]
  workoutLogs  WorkoutLog[]
}

model WorkoutPlan {
  id            String        @id @default(uuid())
  coachId       String
  clientId      String
  title         String
  description   String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  coach         CoachProfile  @relation(fields: [coachId], references: [id])
  client        ClientProfile @relation(fields: [clientId], references: [id])
  workoutSplits WorkoutSplit[]
  workoutLogs   WorkoutLog[]
}

model WorkoutSplit {
  id            String        @id @default(uuid())
  workoutPlanId String
  day           String
  isRestDay     Boolean       @default(false)
  name          String?
  muscleGroups  String?
  workoutPlan   WorkoutPlan   @relation(fields: [workoutPlanId], references: [id])
  exercises     Exercise[]
  workoutLogs   WorkoutLog[]
}

model Exercise {
  id             String        @id @default(uuid())
  workoutSplitId String
  name           String
  sets           Int
  reps           Int
  weight         Float?
  order          Int
  notes          String?
  workoutSplit   WorkoutSplit  @relation(fields: [workoutSplitId], references: [id])
  exerciseLogs   ExerciseLog[]
}

model WorkoutLog {
  id            String        @id @default(uuid())
  clientId      String
  planId        String
  splitId       String
  note          String?
  loggedAt      DateTime      @default(now())
  client        ClientProfile @relation(fields: [clientId], references: [id])
  plan          WorkoutPlan   @relation(fields: [planId], references: [id])
  split         WorkoutSplit  @relation(fields: [splitId], references: [id])
  exerciseLogs  ExerciseLog[]
}

model ExerciseLog {
  id           String     @id @default(uuid())
  workoutLogId String
  exerciseId   String
  weightUsed   Float?
  repsActual   Int?
  setNumber    Int
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id])
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])
}

model Invitation {
  id          String      @id @default(uuid())
  coachId     String      @default(uuid()) 
  inviteCode  String      @default(uuid()) @unique
  isUsed      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  coach CoachProfile @relation(fields: [coachId], references: [id])
}